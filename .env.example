# Copy to .env (never commit .env). Use scripts/sync-railway-env.sh to push to Railway.

# Moonshot / Kimi (OpenAI-compatible)
LLM_API_KEY=
LLM_BASE_URL=https://api.moonshot.ai/v1
LLM_MODEL=kimi-k2-turbo-preview

# Aristotle CLI (https://harmonic.fun / your provider)
ARISTOTLE_API_KEY=

# Persisted on a Railway volume mounted at /data
DATABASE_PATH=/data/orchestrator.db

# Per-campaign Lean workspaces: WORKSPACE_ROOT/<campaign_id>/
WORKSPACE_ROOT=/data/workspaces
# If you previously used a single shared directory, set this to that path once; the app migrates rows on startup.
WORKSPACE_LEGACY_DIR=/data/workspace
# Backward-compat alias read by WORKSPACE_LEGACY_DIR when WORKSPACE_LEGACY_DIR is unset
# WORKSPACE_DIR=/data/workspace

# Default template when the form/API omits it: minimal | mathlib
# DEFAULT_WORKSPACE_TEMPLATE=minimal

# Optional admin JSON + UI (Bearer token, X-Admin-Token, or ?admin_token=)
# ADMIN_TOKEN=

# Research methodology (open problems) — see README "Research methodology"
# VERDICT_RECONCILE_FROM_SUMMARY=1
# MANAGER_MIN_NON_PROVE_MOVES_PER_BATCH=1
# SKEPTIC_PASS_ENABLED=0
# SKEPTIC_PASS_MAX_EXPERIMENTS=2
# MAP_PROVED_GATE_KINDS=obstruction,equivalence

# Optional tuning
# LLM_JSON_MODE=0
# TICK_INTERVAL=30
# MAX_ACTIVE_EXPERIMENTS=5
# MAX_EXPERIMENTS=100
# LLM_EVIDENCE_TARGET_TAIL=24
# LLM_EXPERIMENT_SUMMARY_CHARS=4000
# LLM_RECENT_STRUCTURED_EXPERIMENTS=12
# LLM_LEDGER_ENTRIES_LIMIT=40
# LLM_SUMMARIZE_INPUT_CHARS=50000

# Mathlib hints via LeanSearch (optional; uses HTTPS to leansearch.net)
# MATHLIB_KNOWLEDGE_MODE=leansearch
# LEAN_TOOLCHAIN_HINT=leanprover/lean4:v4.22.0
# LEANSEARCH_API_URL=https://leansearch.net/search
